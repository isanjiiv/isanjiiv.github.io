        <div class="project-header">
          <h1 class="project-title">Windows Server Domain Setup + GPO Automation + Backup & Recovery</h1>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
              <span class="tech-tag" style="background:var(--bg-secondary); border:none; color:var(--text-muted);">Windows Server 2022</span>
              <span class="tech-tag" style="background:var(--bg-secondary); border:none; color:var(--text-muted);">Active Directory (AD DS)</span>
              <span class="tech-tag" style="background:var(--bg-secondary); border:none; color:var(--text-muted);">DNS</span>
              <span class="tech-tag" style="background:var(--bg-secondary); border:none; color:var(--text-muted);">Group Policy (GPO)</span>
